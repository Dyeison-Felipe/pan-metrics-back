#!/bin/sh

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE" | tr -d '\n')

PATTERN="^(feat|fix|chore|docs|refactor|test|style):"

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ Erro: Mensagem de commit inválida."
  echo "Use: feat:, fix:, chore:, docs:, refactor:, test: ou style:"
  echo ""
  exit 1
fi

if [ ${#COMMIT_MSG} -gt 72 ]; then
  echo ""
  echo "❌ Erro: Mensagem muito longa."
  echo "Máximo permitido: 72 caracteres."
  echo ""
  exit 1 
fi

exit 0
